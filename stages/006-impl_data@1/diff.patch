+    def _apply_single_move(self, record: MoveRecord):
+        # Remove from from_pos
+        if record.from_pos.type == LocationType.FREECELL:
+            self.freecells[record.from_pos.index] = None
+        elif record.from_pos.type == LocationType.TABLEAU:
