+    
+    assert state.tableaus[0] == []
+    assert state.tableaus[1] == [cJ, c10]
+    
+    # 2. Undo the move
+    undo_success = state.undo()
+    assert undo_success is True
+    assert state.tableaus == orig_tableaus
+    assert state.freecells == orig_freecells
