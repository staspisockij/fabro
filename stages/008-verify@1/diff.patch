+            serde_json::from_slice(&materialized.submitted_manifest_bytes)
+                .expect("submitted bytes should be a manifest");
+        assert_eq!(
+            submitted_manifest,
+            serde_json::to_value(&materialized.manifest).unwrap()
+        );
+    }
