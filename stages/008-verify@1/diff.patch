+                        Arc::clone(&steering_hub),
+                        Arc::clone(&catalog),
+                    ),
+                ))
+            })
+        })
+        .env_lookup(move |name| match name {
+            "OPENAI_API_KEY" => Some(env_api_key.clone()),
+            _ => None,
+        })
+        .build();
+    test_app_with_scheduler(state)
+}
